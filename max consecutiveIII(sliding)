class Solution:
    def longestOnes(self, nums: List[int], k: int) -> int:
        left=0
        n=len(nums)
        ans=0
        zerocount=0
        for right in range(n):
            if nums[right]==0:
                zerocount+=1
            while zerocount>k:
                if nums[left]==0:
                    zerocount-=1
                left+=1
            ans=max(ans,right-left+1)
        return ans
