class Solution:
    def minSubArrayLen(self, target: int, nums: List[int]) -> int:
        left = 0
        total = 0
        n=len(nums)
        ans = float('inf')
        for right in range(n):
            total += nums[right]
            while total >= target:
                total-=nums[left]
                ans=min(ans,right-left+1)
                left += 1
        return 0 if ans == float('inf') else ans
