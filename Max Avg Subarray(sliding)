class Solution:
    def findMaxAverage(self, nums: List[int], k: int) -> float:
        n=len(nums)
        window_sum=0
        for i in range(k):
            window_sum+=nums[i]
        max_sum=window_sum
        for j in range(k,n):
            window_sum+=nums[j]
            window_sum-=nums[j-k]
            max_sum=max(max_sum,window_sum)
        return max_sum/k     
