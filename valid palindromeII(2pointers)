class Solution:
    def validPalindrome(self, s: str) -> bool:
        l = 0
        r = len(s) - 1
        def check(l, r):
            while l < r:
                if s[l] != s[r]:
                    return False
                else:
                    l += 1
                    r -= 1
            return True
        while l < r:
            if s[l] == s[r]:
                l += 1
                r -= 1
            else:
                return check(l, r - 1) or check(l + 1, r)
        return True
