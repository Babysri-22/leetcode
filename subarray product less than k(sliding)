class Solution:
    def numSubarrayProductLessThanK(self, nums: List[int], k: int) -> int:
        left=0
        n=len(nums)
        count=0
        product=1
        if k<=1:
            return 0
        for right in range(n):
            product*=nums[right]
            while product>=k:
                product//=nums[left]
                left+=1
            count+=right-left+1
        return count
